<%- include('../partials/sidebar', { title: title, user: user, activePage: 'trainers' }) %>
<div class="mgmt-container">

    <div class="page-header">
      <h1 class="page-title">Add Trainer</h1>
    </div>

    <div class="sub-nav">
      <a href="/trainers"     class="sub-nav-link">Trainers List</a>
      <a href="/trainers/new" class="sub-nav-link active">Add Trainer</a>
    </div>

    <% if (flash) { %>
      <div class="alert-msg alert-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert-msg alert-error">
        <strong>Please fix the following errors:</strong>
        <ul>
          <% errors.forEach(function(e) { %><li><%= e %></li><% }); %>
        </ul>
      </div>
    <% } %>

    <div class="form-page" style="padding:0 0 20px;">
      <p class="muted">This page creates a trainer login account. Trainers can log in, manage their assigned members, and record PT sessions.</p>
    </div>

    <form method="POST" action="/trainers" class="panel form-page vertical-form">

      <div class="form-section">
        <div class="form-section-title">Trainer Details</div>
        <div class="form-group">
          <label class="form-label" for="name">Full Name <span class="required">*</span></label>
          <input id="name" name="name" type="text" class="form-input"
                 value="<%= values.name || '' %>" placeholder="Trainer full name" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email <span class="required">*</span></label>
          <input id="email" name="email" type="email" class="form-input"
                 value="<%= values.email || '' %>" placeholder="trainer@gym.com" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" class="form-input"
                 value="<%= values.phone || '' %>" placeholder="98765xxxxx">
        </div>
      </div>

      <div class="form-section">
        <div class="form-section-title">Login Password</div>
        <div class="form-group">
          <label class="form-label" for="password">Password <span class="required">*</span></label>
          <input id="password" name="password" type="password" class="form-input"
                 placeholder="Minimum 6 characters" required>
          <small class="form-hint">Password is stored as a secure bcrypt hash. You cannot view it after saving.</small>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn primary">Add Trainer</button>
        <a href="/trainers" class="btn">Cancel</a>
      </div>
    </form>

  </div>

<%- include('../partials/sidebar-foot') %>
