<%- include('../partials/sidebar', { title: title, user: user, activePage: 'members' }) %>
<div class="mgmt-container">

    <div class="page-header">
      <h1 class="page-title">Add Public Member</h1>
    </div>

    <!-- Sub-navigation -->
    <div class="sub-nav">
      <a href="/members"     class="sub-nav-link">Members List</a>
      <a href="/members/new" class="sub-nav-link active">Add Public Member</a>
      <% if (user && user.role === 'manager') { %>
        <a href="/members/import" class="sub-nav-link">Import Excel</a>
      <% } %>
    </div>

    <div class="form-page" style="padding:0 0 20px;">
      <p class="muted">This page is for adding gym customers and clients. Public members do not get login access. They use the Attendance Desk to mark attendance.</p>
    </div>

    <% if (flash) { %>
      <div class="alert-msg alert-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="alert-msg alert-error">
        <strong>Please fix the following errors:</strong>
        <ul>
          <% errors.forEach(function(e) { %><li><%= e %></li><% }); %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/members" class="member-form panel form-page vertical-form">

      <!-- Basic Details -->
      <div class="form-section">
        <div class="form-section-title">Basic Details</div>
        <div class="form-group">
          <label class="form-label" for="memberNo">Member Number <span class="required">*</span></label>
          <input id="memberNo" name="memberNo" type="text" class="form-input"
                 value="<%= values.memberNo || '' %>" placeholder="e.g. 1004" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="fullName">Full Name <span class="required">*</span></label>
          <input id="fullName" name="fullName" type="text" class="form-input"
                 value="<%= values.fullName || '' %>" placeholder="Member full name" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" class="form-input"
                 value="<%= values.phone || '' %>" placeholder="98765xxxxx">
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input id="email" name="email" type="email" class="form-input"
                 value="<%= values.email || '' %>" placeholder="member@example.com">
        </div>
        <div class="form-group">
          <label class="form-label" for="gender">Gender</label>
          <select id="gender" name="gender" class="form-input">
            <option value="">Select gender</option>
            <option value="Male"   <%= values.gender === 'Male'   ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= values.gender === 'Female' ? 'selected' : '' %>>Female</option>
            <option value="Other"  <%= values.gender === 'Other'  ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="dateOfBirth">Date of Birth</label>
          <input id="dateOfBirth" name="dateOfBirth" type="date" class="form-input"
                 value="<%= values.dateOfBirth || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="address">Address</label>
          <input id="address" name="address" type="text" class="form-input"
                 value="<%= values.address || '' %>" placeholder="Area / city">
        </div>
      </div>

      <!-- Plan Details -->
      <div class="form-section">
        <div class="form-section-title">Plan Details</div>
        <div class="form-group">
          <label class="form-label" for="planName">Plan Name</label>
          <input id="planName" name="planName" type="text" class="form-input"
                 value="<%= values.planName || 'Monthly' %>" placeholder="Monthly / 6 Months / 1 Year">
        </div>
        <div class="form-group">
          <label class="form-label" for="planDurationMonths">Duration (months)</label>
          <input id="planDurationMonths" name="planDurationMonths" type="number"
                 min="1" max="120" class="form-input"
                 value="<%= values.planDurationMonths || '' %>" placeholder="e.g. 1, 6, 12">
        </div>
        <div class="form-group">
          <label class="form-label" for="planStartDate">Plan Start Date</label>
          <input id="planStartDate" name="planStartDate" type="date" class="form-input"
                 value="<%= values.planStartDate || new Date().toISOString().slice(0,10) %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="planEndDate">Plan End Date</label>
          <input id="planEndDate" name="planEndDate" type="date" class="form-input"
                 value="<%= values.planEndDate || '' %>">
          <small class="form-hint">Auto-fills if you enter start date and duration.</small>
        </div>
        <div class="form-group">
          <label class="form-label" for="notificationEnabled">Plan Expiry Notification</label>
          <select id="notificationEnabled" name="notificationEnabled" class="form-input">
            <option value="true"  <%= (values.notificationEnabled === undefined || values.notificationEnabled === 'true' || values.notificationEnabled === true) ? 'selected' : '' %>>Enabled</option>
            <option value="false" <%= (values.notificationEnabled === 'false' || values.notificationEnabled === false) ? 'selected' : '' %>>Disabled</option>
          </select>
        </div>
      </div>

      <!-- Emergency Contact -->
      <div class="form-section">
        <div class="form-section-title">Emergency Contact</div>
        <div class="form-group">
          <label class="form-label" for="emergencyContactName">Contact Name</label>
          <input id="emergencyContactName" name="emergencyContactName" type="text" class="form-input"
                 value="<%= values.emergencyContactName || '' %>" placeholder="Emergency contact person">
        </div>
        <div class="form-group">
          <label class="form-label" for="emergencyContactPhone">Contact Phone</label>
          <input id="emergencyContactPhone" name="emergencyContactPhone" type="tel" class="form-input"
                 value="<%= values.emergencyContactPhone || '' %>" placeholder="Emergency phone number">
        </div>
      </div>

      <!-- Trainer Assignment -->
      <div class="form-section">
        <div class="form-section-title">Trainer Assignment</div>
        <div class="form-group">
          <label class="form-label" for="assignedTrainerId">Assigned Trainer</label>
          <select id="assignedTrainerId" name="assignedTrainerId" class="form-input">
            <option value="">No trainer assigned</option>
            <% trainers.forEach(function(t) { %>
              <option value="<%= t.id %>" <%= values.assignedTrainerId === t.id ? 'selected' : '' %>>
                <%= t.name %> (<%= t.email %>)
              </option>
            <% }); %>
          </select>
        </div>
      </div>

      <!-- Notes -->
      <div class="form-section">
        <div class="form-section-title">Notes</div>
        <div class="form-group">
          <label class="form-label" for="notes">Notes</label>
          <textarea id="notes" name="notes" class="form-input form-textarea"
                    placeholder="Fitness goal, health notes, etc."><%= values.notes || '' %></textarea>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn primary">Add Member</button>
        <a href="/members" class="btn">Cancel</a>
      </div>
    </form>

  </div>

<script>
(function() {
  const startEl    = document.getElementById('planStartDate');
  const durationEl = document.getElementById('planDurationMonths');
  const endEl      = document.getElementById('planEndDate');
  function autoCalcEnd() {
    const start  = startEl.value;
    const months = parseInt(durationEl.value, 10);
    if (start && months > 0 && !endEl.value) {
      const d = new Date(start);
      d.setMonth(d.getMonth() + months);
      endEl.value = d.toISOString().slice(0, 10);
    }
  }
  startEl.addEventListener('change', autoCalcEnd);
  durationEl.addEventListener('change', autoCalcEnd);
})();
</script>

<%- include('../partials/sidebar-foot') %>
